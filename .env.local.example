# Anthropic API key — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Groq API key (used for Whisper voice transcription) — https://console.groq.com
GROQ_API_KEY=

# Neon Postgres connection string — https://console.neon.tech
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
